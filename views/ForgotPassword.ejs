<!DOCTYPE html>
<html lang="en">
  <%- include('includes/head2') %>
<body class="authPage">

    <main class="authContainer">
        <a href="/">
            <img src="/images/logo.webp" alt="Groupify" class="authLogo">
        </a>

        <h1 class="authTitle">
            Forgot Password
        </h1>

        <form action="/forgot-password" method="POST" class="authFormBox">
            <% if (errors && errors.length) { %>
                <% errors.forEach(function(error) { %>
                    <p class="authError"><i class="fa-solid fa-circle-info"></i> <%= error %></p>
                <% }) %>
            <% } %>

            <p class="forgotpassSub">
                Enter your email address to reset your password.
            </p>

            <input 
                type="email" 
                id="email" 
                name="email" 
                autocomplete="email" 
                placeholder="Email" 
                class="authuserInput" required
            />

            <button class="authButton">SEND CODE</button>
        </form>

        <p class="account">
        Know your password?
        <a href="/signin" class="linktoAuth">Sign In</a>
      </p>

    </main>
</body>
</html>